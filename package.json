{
  "name": "pi-rlm",
  "version": "0.1.2",
  "description": "Recursive Language Model (RLM) extension for Pi coding agent",
  "license": "MIT",
  "type": "module",
  "main": "index.ts",
  "bin": {
    "pi-rlm": "./bin/pi-rlm.mjs"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "rlm",
    "recursive-language-model",
    "subagent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manojlds/pi-rlm.git"
  },
  "homepage": "https://github.com/manojlds/pi-rlm",
  "bugs": "https://github.com/manojlds/pi-rlm/issues",
  "files": [
    "index.ts",
    "src",
    "bin",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:cli": "tsc -p tsconfig.cli.json && node ./scripts/build-cli.mjs",
    "prepack": "npm run build:cli",
    "cli": "npm run build:cli --silent && node ./bin/pi-rlm.mjs",
    "pack:check": "npm pack --dry-run",
    "check": "npm run typecheck && npm run pack:check"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@sinclair/typebox": "^0.34.41",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
